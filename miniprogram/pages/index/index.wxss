.page {
  padding: 24rpx;
}

.header,
.search-card,
.card,
.metric-card {
  background: #ffffff;
  border: 1rpx solid #dde5e2;
  border-radius: 16rpx;
  box-shadow: 0 14rpx 40rpx rgba(15, 23, 42, 0.08);
}

.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.title {
  color: #18211f;
  font-size: 36rpx;
  font-weight: 800;
}

.subtitle {
  margin-top: 6rpx;
  color: #66716e;
  font-size: 24rpx;
}

.share-icon {
  width: 72rpx;
  height: 72rpx;
  padding: 0;
  border-radius: 12rpx;
  color: #ffffff;
  background: #0b5f59;
  font-size: 34rpx;
  line-height: 72rpx;
}

.search-card,
.card {
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.label {
  margin-bottom: 10rpx;
  color: #66716e;
  font-size: 24rpx;
  font-weight: 700;
}

.search-row {
  display: flex;
  gap: 14rpx;
}

.search-input {
  flex: 1;
  height: 76rpx;
  border: 1rpx solid #dde5e2;
  border-radius: 12rpx;
  padding: 0 20rpx;
  background: #ffffff;
}

.primary-btn,
.share-btn {
  min-width: 180rpx;
  height: 76rpx;
  border-radius: 12rpx;
  color: #ffffff;
  background: #0b5f59;
  font-weight: 800;
  line-height: 76rpx;
}

.share-btn {
  min-width: 160rpx;
  height: 60rpx;
  font-size: 24rpx;
  line-height: 60rpx;
}

.quick-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 14rpx;
}

.chip {
  height: 56rpx;
  padding: 0 18rpx;
  border: 1rpx solid #dde5e2;
  border-radius: 12rpx;
  color: #66716e;
  background: #ffffff;
  font-size: 24rpx;
  line-height: 56rpx;
}

.status {
  margin-top: 16rpx;
  padding: 18rpx;
  border: 1rpx solid #dde5e2;
  border-radius: 12rpx;
  color: #66716e;
  background: #eef6f5;
  font-size: 24rpx;
}

.status.loading {
  color: #0b5f59;
}

.status.error {
  color: #c2410c;
}

.status.success,
.status.warning {
  color: #a16207;
}

.summary-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.metric-card {
  min-height: 190rpx;
  padding: 24rpx;
}

.metric-card.accent {
  grid-column: 1 / -1;
  background: #fff3d8;
}

.metric-label,
.info-grid text {
  color: #66716e;
  font-size: 24rpx;
  font-weight: 700;
}

.metric-value {
  margin-top: 14rpx;
  color: #0b5f59;
  font-size: 58rpx;
  font-weight: 850;
  line-height: 1;
}

.accent .metric-value {
  color: #b7791f;
}

.metric-unit,
.price-line,
.market-line,
.insight,
.method-reason,
.disclaimer {
  color: #66716e;
  font-size: 24rpx;
}

.price-line,
.market-line,
.info-grid small {
  display: block;
  margin-top: 8rpx;
  color: #b7791f;
  font-size: 24rpx;
  font-weight: 800;
}

.market-line.danger {
  color: #c2410c;
}

.market-line.success {
  color: #15803d;
}

.card-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 18rpx;
}

.card-title {
  color: #18211f;
  font-size: 32rpx;
  font-weight: 850;
}

.standalone {
  margin-bottom: 18rpx;
}

.badge {
  max-width: 320rpx;
  padding: 8rpx 16rpx;
  border: 1rpx solid #dde5e2;
  border-radius: 999rpx;
  color: #0b5f59;
  background: #eef6f5;
  font-size: 22rpx;
  font-weight: 800;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.info-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
}

.info-grid > view,
.buy-grid > view {
  min-height: 118rpx;
  padding: 18rpx;
  border: 1rpx solid #dde5e2;
  border-radius: 12rpx;
  background: #eef6f5;
}

.info-grid strong,
.buy-grid strong {
  display: block;
  margin-top: 10rpx;
  color: #0b5f59;
  font-size: 34rpx;
  font-weight: 850;
  word-break: break-all;
}

.insight {
  margin-top: 18rpx;
  line-height: 1.6;
}

.forecast-bars {
  display: flex;
  align-items: flex-end;
  justify-content: space-around;
  height: 300rpx;
  margin: 24rpx 0 12rpx;
  border-bottom: 1rpx solid #dde5e2;
}

.bar-item {
  width: 28%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-end;
}

.bar-wrap {
  width: 86rpx;
  height: 210rpx;
  display: flex;
  align-items: flex-end;
}

.bar {
  width: 100%;
  min-height: 12rpx;
  border-radius: 10rpx 10rpx 0 0;
  background: #0f766e;
}

.bar-value {
  margin-top: 8rpx;
  color: #0b5f59;
  font-size: 24rpx;
  font-weight: 800;
}

.bar-label {
  margin-top: 4rpx;
  color: #66716e;
  font-size: 22rpx;
}

.banker {
  border-color: #d6b06c;
}

.adaptive {
  border-color: #b9d8d3;
}

.method-card {
  margin-top: 18rpx;
  padding: 18rpx;
  border: 1rpx solid #dde5e2;
  border-radius: 12rpx;
  background: #eef6f5;
}

.method-title {
  color: #18211f;
  font-size: 28rpx;
  font-weight: 850;
}

.method-reason {
  margin: 8rpx 0 14rpx;
  line-height: 1.5;
}

.method-row {
  display: grid;
  grid-template-columns: 1fr 1.5fr 1.3fr 1fr;
  gap: 8rpx;
  padding: 12rpx 0;
  border-top: 1rpx solid #dde5e2;
  color: #18211f;
  font-size: 22rpx;
}

.method-row.head {
  color: #66716e;
  font-weight: 800;
}

.buy-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
}

.buy-grid text {
  color: #66716e;
  font-size: 24rpx;
  font-weight: 700;
}

.buy-grid small {
  display: block;
  margin-top: 8rpx;
  color: #b7791f;
  font-size: 22rpx;
  font-weight: 800;
}

.disclaimer {
  padding: 12rpx 4rpx 36rpx;
  text-align: center;
}
